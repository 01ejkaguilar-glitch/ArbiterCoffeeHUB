DirectoryIndex index.html
# React SPA — Apache config for XAMPP / production

Options -MultiViews
RewriteEngine On

# ── Permissions-Policy header ────────────────────────────────────────────────
# Allows the unload event (used by webpack runtime & Pusher/Laravel Echo).
# Chrome 115+ blocks unload by default; this header re-enables it for this origin.
<IfModule mod_headers.c>
    Header always set Permissions-Policy "unload=*"
</IfModule>

# ── SPA fallback: route all non-file/dir requests to index.html ──────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [QSA,L]
